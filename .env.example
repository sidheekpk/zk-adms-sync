# --- Shared / dev compose -------------------------------------------
DATABASE_URL=postgres://zkc:zkc_dev@localhost:5432/zkc
REDIS_URL=redis://localhost:6379

# --- Better Auth ----------------------------------------------------
BETTER_AUTH_SECRET=replace-with-32-bytes-of-randomness
BETTER_AUTH_URL=http://localhost:3000

# --- Web (Next.js) --------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- ADMS service ---------------------------------------------------
ADMS_PORT=8080
ADMS_HOST=0.0.0.0

# --- First-run bootstrap (super-admin platform account) -------------
BOOTSTRAP_SUPER_ADMIN_EMAIL=admin@radixhr.app
BOOTSTRAP_SUPER_ADMIN_PASSWORD=change-on-first-login

LOG_LEVEL=info
